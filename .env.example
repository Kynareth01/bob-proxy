# IBM Bob Shell API Key (from bob.ibm.com → API Keys → Inference type)
BOBSHELL_API_KEY=your_ibm_bob_api_key_here

# Proxy API Key (optional, protects this proxy from unauthorized access)
# Set this to any random string to secure your proxy
PROXY_API_KEY=

# Server config
PORT=8787
HOST=0.0.0.0

# Bob Shell config
MAX_CONCURRENT=4
BOB_TIMEOUT=120
DEFAULT_MODEL=ibm-bob
